---
import BaseLayout from "../layouts/BaseLayout.astro";
import Gallery from "../components/Gallery.astro";

// Demonstration of the Gallery component using the sequential MVMIP setup gifs.
// This page is not linked from the nav; it exists only to preview the widget.
const images = Array.from({ length: 8 }, (_, i) => ({
  src: `/posts/5/gifs/mvmip_setup${i + 1}.gif`,
  alt: `MVMIP setup ${i + 1}`,
  caption: `MVMIP setup ${i + 1} of 8`,
}));
---

<BaseLayout
  pageTitle="Gallery demo"
  header={{ kind: "page", title: "Gallery demo" }}
>
  <div class="container" role="main">
    <div class="row">
      <div class="col-xl-8 col-lg-offset-2 col-md-10 col-md-offset-1">
        <article role="main" class="blog-post">
          <p>
            A scrollable gallery: use the arrows, the dots, or swipe/scroll the
            strip to page through images inside one widget instead of stacking
            them. This is the reusable kind of component the new setup makes
            possible. In an actual post you would just write
            <code>{"<Gallery images={...} />"}</code>.
          </p>
          <Gallery images={images} />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>
