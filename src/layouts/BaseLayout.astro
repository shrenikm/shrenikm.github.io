---
import Nav from "../components/Nav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_NAME, GA_MEASUREMENT_ID } from "../consts";

interface HeaderProps {
  kind: "home" | "post" | "page" | "list";
  title?: string;
  date?: Date;
  hashTitle?: boolean;
}

interface Props {
  pageTitle?: string;
  description?: string;
  header: HeaderProps;
}

const { pageTitle, description, header } = Astro.props;
const fullTitle = pageTitle ? `${pageTitle} - ${SITE_NAME}` : SITE_NAME;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />

    {
      GA_MEASUREMENT_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
          />
          <script is:inline define:vars={{ gaId: GA_MEASUREMENT_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", gaId);
          </script>
        </>
      )
    }
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="author" content="Shrenik Muralidhar" />
    <link rel="alternate" href="/rss.xml" type="application/rss+xml" title={SITE_NAME} />

    <!-- Third party styles from CDN (matches the original non self hosted theme setup). -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.7/dist/katex.min.css"
    />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v6.6.0/css/all.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css"
    />
    <!-- Theme styles copied from the forked beautifulhugo theme. Fonts (Lora +
         Open Sans) are self hosted via fonts.css to match the original theme
         exactly, rather than pulling newer redrawn versions from a CDN. -->
    <link rel="stylesheet" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/highlight.min.css" />
    <link rel="stylesheet" href="/css/codeblock.css" />
    <link rel="stylesheet" href="/css/custom.css" />
  </head>
  <body>
    <Nav />
    <Header {...header} />
    <slot />
    <Footer />

    <!-- Scripts: jQuery + bootstrap for the navbar, highlight.js for code blocks. -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js"></script>
    <script is:inline src="/js/highlight.min.js"></script>
    <script is:inline src="/js/main.js"></script>
    <script is:inline>
      if (window.hljs) {
        document.querySelectorAll("pre code").forEach((el) => window.hljs.highlightElement(el));
      }
    </script>
  </body>
</html>
